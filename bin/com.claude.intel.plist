<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.claude.intel</string>

    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/python3</string>
        <string>/Users/antesucue/agents/claude-news/main.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/antesucue/agents/claude-news</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>StandardOutPath</key>
    <string>/Users/antesucue/agents/claude-news/logs/launchd-stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/antesucue/agents/claude-news/logs/launchd-stderr.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin:/Users/antesucue/.local/bin</string>
        <key>HOME</key>
        <string>/Users/antesucue</string>
    </dict>
</dict>
</plist>
